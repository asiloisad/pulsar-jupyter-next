{
  "name": "jupyter-next",
  "description": "Open and edit Jupyter notebooks",
  "repository": "https://github.com/asiloisad/pulsar-jupyter-next",
  "keywords": [
    "jupyter",
    "notebook",
    "ipynb",
    "python",
    "editor"
  ],
  "version": "1.1.0",
  "license": "MIT",
  "engines": {
    "atom": ">=1.100.0 <2.0.0"
  },
  "main": "./lib/main",
  "activationHooks": [
    "core:loaded-shell-environment"
  ],
  "deserializers": {
    "JupyterNotebookEditor": "deserializeNotebookEditor"
  },
  "consumedServices": {
    "tree-view": {
      "versions": {
        "1.0.0": "consumeTreeView"
      }
    },
    "simplemap": {
      "versions": {
        "1.0.0": "consumeSimpleMap"
      }
    }
  },
  "providedServices": {
    "jupyter": {
      "versions": {
        "1.0.0": "provideJupyter"
      }
    },
    "hydrogen-adapter": {
      "versions": {
        "1.0.0": "provideHydrogenAdapter"
      }
    },
    "linter-adapter": {
      "versions": {
        "1.0.0": "provideLinterItemAdapter"
      }
    },
    "linter-ui": {
      "versions": {
        "1.0.0": "provideLinterUI"
      }
    },
    "navigation-adapter": {
      "versions": {
        "1.0.0": "provideNavigationAdapter"
      }
    }
  },
  "dependencies": {
    "anser": "^2.3.3",
    "plotly.js-dist": "^3.6.0",
    "uuid": "^11.1.0"
  },
  "configSchema": {
    "notebook": {
      "order": 1,
      "title": "Notebook",
      "description": "Notebook-level settings.",
      "type": "object",
      "collapsed": true,
      "properties": {
        "useOpener": {
          "order": 1,
          "title": "Use Workspace Opener",
          "description": "Open .ipynb files with jupyter-next through the Pulsar workspace opener.",
          "type": "boolean",
          "default": true
        }
      }
    },
    "input": {
      "order": 2,
      "title": "Input Cell",
      "description": "Input cell display and editing settings.",
      "type": "object",
      "collapsed": true,
      "properties": {
        "maxHeight": {
          "order": 1,
          "title": "Max Height",
          "description": "Maximum height in pixels for input cells. Zero means unlimited.",
          "type": "integer",
          "default": 0,
          "minimum": 0
        }
      }
    },
    "output": {
      "order": 3,
      "title": "Output Cell",
      "description": "Output cell display settings.",
      "type": "object",
      "collapsed": true,
      "properties": {
        "maxHeight": {
          "order": 1,
          "title": "Max Height",
          "description": "Maximum height in pixels for output cells before scrolling.",
          "type": "integer",
          "default": 1000,
          "minimum": 100
        }
      }
    },
    "scrollmap": {
      "order": 4,
      "title": "Scrollmap",
      "description": "Scrollmap marker settings.",
      "type": "object",
      "collapsed": true,
      "properties": {
        "enabled": {
          "order": 1,
          "title": "Show Scrollmap",
          "description": "Show markdown heading and selected cell markers on the notebook scrollbar when the scrollmap package is available.",
          "type": "boolean",
          "default": true
        },
        "threshold": {
          "order": 2,
          "title": "Threshold",
          "description": "Hide scrollmap markers if their count exceeds this value. Zero means no limit.",
          "type": "integer",
          "default": 0,
          "minimum": 0
        },
        "depth": {
          "order": 3,
          "title": "Depth",
          "description": "Maximum markdown heading depth to show in the scrollmap. Zero means no limit.",
          "type": "integer",
          "default": 0,
          "minimum": 0
        }
      }
    }
  }
}
